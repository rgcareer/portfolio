---
// Ink-wash trail: a faint vermilion stroke follows pointer velocity and
// evaporates. Pen on paper — the successor to the old particle field, in the
// manual's language. Fine-pointer only, DPR-capped, pauses when idle/hidden.
---
<canvas id="ink" class="ink" aria-hidden="true"></canvas>

<style>
  .ink { display: none; }
  @media (hover: hover) and (pointer: fine) {
    .ink { display: block; position: fixed; inset: 0; z-index: -1; pointer-events: none; }
  }
  @media (prefers-reduced-motion: reduce) { .ink { display: none !important; } }
</style>

<script>
  const cv = document.getElementById('ink') as HTMLCanvasElement | null;
  const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (cv && fine && !reduce) {
    const ctx = cv.getContext('2d')!;
    const dpr = Math.min(devicePixelRatio || 1, 1.5);
    let w = 0, h = 0;
    const size = () => {
      w = innerWidth; h = innerHeight;
      cv.width = w * dpr; cv.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    };
    size();
    addEventListener('resize', size);

    type Pt = { x: number; y: number; age: number; wd: number };
    let pts: Pt[] = [];
    let last: { x: number; y: number } | null = null;
    let raf = 0, running = false;
    const LIFE = 46; // frames to evaporate

    const loop = () => {
      ctx.clearRect(0, 0, w, h);
      for (let i = 1; i < pts.length; i++) {
        const a = pts[i - 1], b = pts[i];
        if (b.age > LIFE) continue;
        const fade = 1 - b.age / LIFE;
        ctx.strokeStyle = `rgba(194, 58, 20, ${0.13 * fade})`;
        ctx.lineWidth = b.wd * fade + 0.4;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.quadraticCurveTo(a.x, a.y, (a.x + b.x) / 2, (a.y + b.y) / 2);
        ctx.stroke();
      }
      pts.forEach((p) => p.age++);
      pts = pts.filter((p) => p.age <= LIFE);
      if (pts.length) { raf = requestAnimationFrame(loop); }
      else { running = false; ctx.clearRect(0, 0, w, h); }
    };
    const wake = () => { if (!running) { running = true; raf = requestAnimationFrame(loop); } };

    addEventListener('pointermove', (e) => {
      if (last) {
        const dx = e.clientX - last.x, dy = e.clientY - last.y;
        const d = Math.hypot(dx, dy);
        if (d < 3) return;
        const speed = Math.min(d, 42);
        pts.push({ x: e.clientX, y: e.clientY, age: 0, wd: 1 + speed * 0.16 });
        if (pts.length > 130) pts.splice(0, pts.length - 130);
      }
      last = { x: e.clientX, y: e.clientY };
      wake();
    }, { passive: true });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) { cancelAnimationFrame(raf); running = false; }
      else if (pts.length) wake();
    });
  }
</script>
