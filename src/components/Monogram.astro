---
// Liquid-metal RG monogram. Pure SVG: chrome gradient + a static turbulence
// displacement (the "liquid" warp) + a sweeping specular highlight (CSS, reduced-motion safe).
interface Props { size?: string; }
const { size = 'clamp(120px, 16vw, 188px)' } = Astro.props;
---
<div class="mono" style={`--mono-size:${size}`} aria-hidden="true">
  <svg viewBox="0 0 200 200" width="100%" height="100%">
    <defs>
      <radialGradient id="mono-glow" cx="50%" cy="46%" r="56%">
        <stop offset="0%" stop-color="rgba(74,222,128,0.20)" />
        <stop offset="100%" stop-color="rgba(74,222,128,0)" />
      </radialGradient>
      <linearGradient id="mono-chrome" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#EEF3F8" />
        <stop offset="18%" stop-color="#97A3B2" />
        <stop offset="36%" stop-color="#FFFFFF" />
        <stop offset="52%" stop-color="#5C6772" />
        <stop offset="68%" stop-color="#C9D2DC" />
        <stop offset="84%" stop-color="#363F49" />
        <stop offset="100%" stop-color="#12171D" />
      </linearGradient>
      <linearGradient id="mono-shine" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(255,255,255,0)" />
        <stop offset="50%" stop-color="rgba(255,255,255,0.9)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0)" />
      </linearGradient>
      <clipPath id="mono-clip">
        <text x="100" y="139" text-anchor="middle" font-family="Geist, system-ui, sans-serif" font-size="126" font-weight="700" letter-spacing="-7">RG</text>
      </clipPath>
      <filter id="mono-liquid" x="-12%" y="-12%" width="124%" height="124%">
        <feTurbulence type="fractalNoise" baseFrequency="0.011 0.016" numOctaves="2" seed="11" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="4" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
    <circle cx="100" cy="92" r="94" fill="url(#mono-glow)" />
    <g filter="url(#mono-liquid)">
      <text x="100" y="139" text-anchor="middle" font-family="Geist, system-ui, sans-serif" font-size="126" font-weight="700" letter-spacing="-7" fill="url(#mono-chrome)">RG</text>
      <g clip-path="url(#mono-clip)">
        <rect class="mono__shine" x="0" y="0" width="46" height="200" fill="url(#mono-shine)" />
      </g>
    </g>
  </svg>
</div>

<style>
  .mono { width: var(--mono-size); height: var(--mono-size); display: block; }
  .mono__shine { transform: translateX(-60px) skewX(-14deg); animation: mono-sweep 4.2s var(--ease) infinite; }
  @keyframes mono-sweep {
    0% { transform: translateX(-60px) skewX(-14deg); }
    55% { transform: translateX(224px) skewX(-14deg); }
    100% { transform: translateX(224px) skewX(-14deg); }
  }
  @media (prefers-reduced-motion: reduce) { .mono__shine { animation: none; opacity: 0; } }
</style>
