---
import BaseLayout from './BaseLayout.astro';
import { getCase, work } from '../config/work';
import { site } from '../config/site';

interface Props { slug: string; }
const { slug } = Astro.props;
const c = getCase(slug)!;
const idx = work.findIndex((w) => w.slug === slug);
const next = work[(idx + 1) % work.length];
---

<BaseLayout title={c.title} active="work" description={c.tagline}>
  <article class="cs container">
    <a href="/work" class="cs__back" data-anim><span aria-hidden="true">←</span> All work</a>

    <div class="cs__layout">
      <aside class="cs__rail">
        <span class="eyebrow" data-anim>// case study · {c.year}</span>
        <dl class="cs__meta" data-anim>
          <div><dt>Role</dt><dd>{c.role}</dd></div>
          <div><dt>Status</dt><dd>{c.status}</dd></div>
          <div><dt>Stack</dt><dd>{c.stack.join(' · ')}</dd></div>
        </dl>
      </aside>

      <div class="cs__main">
        <h1 class="cs__title" data-anim>{c.title}</h1>
        <p class="cs__tagline" data-anim>{c.tagline}</p>

        <div class="cs__metrics" data-anim>
          {c.metrics.map((m) => (
            <div class="cs__metric">
              <span class="cs__metric-v">{m.value}</span>
              <span class="cs__metric-l">{m.label}</span>
            </div>
          ))}
        </div>

        <div class="cs__body prose">
          <slot />
        </div>

        <nav class="cs__next" aria-label="Next case study">
          <a href={`/work/${next.slug}`} class="bezel cs__next-card">
            <span class="bezel__core cs__next-core">
              <span class="cs__next-k">Next case study →</span>
              <span class="cs__next-t">{next.title}</span>
            </span>
          </a>
          <a href={`mailto:${site.email}`} class="btn btn--accent magnetic cs__next-cta">
            Get in touch
            <span class="btn__ic" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
            </span>
          </a>
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .cs { padding-top: clamp(2.5rem, 6vw, 4.5rem); }
  .cs__back { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono);
    font-size: var(--fs-sm); color: var(--text-dim); transition: color var(--t-fast) var(--ease); }
  .cs__back:hover { color: var(--text); }
  .cs__back span { transition: transform var(--t) var(--ease); }
  .cs__back:hover span { transform: translateX(-3px); }

  .cs__layout { display: grid; gap: clamp(2rem, 5vw, 4rem); margin-top: 2.2rem; }
  @media (min-width: 900px) {
    .cs__layout { grid-template-columns: 230px minmax(0, 1fr); align-items: start; }
    .cs__rail { position: sticky; top: 6rem; }
  }
  .cs__main { min-width: 0; }

  .cs__rail .eyebrow { display: inline-flex; }
  .cs__meta { display: flex; flex-wrap: wrap; gap: 1.2rem 2.2rem; margin-top: 1.4rem; }
  @media (min-width: 900px) {
    .cs__meta { flex-direction: column; gap: 1.3rem; margin-top: 1.6rem; padding-top: 1.5rem;
      border-top: 0.5px solid var(--line); }
  }
  .cs__meta dt { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.16em; color: var(--text-faint); margin-bottom: 0.35rem; }
  .cs__meta dd { font-size: var(--fs-sm); color: var(--text); max-width: 22ch; }

  .cs__title { font-size: var(--fs-3xl); }
  .cs__tagline { font-size: var(--fs-xl); color: var(--text-dim); margin-top: 1.1rem; max-width: 44ch; }

  .cs__metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 2rem; }
  .cs__metric { background: rgba(255,255,255,0.025); border: 0.5px solid var(--line); border-radius: var(--r-md); padding: 1rem 1.1rem; }
  .cs__metric-v { display: block; font-size: var(--fs-2xl); color: var(--accent); letter-spacing: -0.02em; }
  .cs__metric-l { display: block; font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-faint); margin-top: 0.4rem; }
  @media (max-width: 600px) { .cs__metrics { grid-template-columns: 1fr; } }

  .cs__body { max-width: 760px; margin-top: clamp(2.5rem, 6vw, 4rem); }

  .cs__next { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem; justify-content: space-between;
    margin-top: clamp(3.5rem, 8vw, 6rem); padding-top: 2.5rem; border-top: 0.5px solid var(--line); }
  .cs__next-card { flex: 1 1 260px; }
  .cs__next-core { display: block; padding: 1.1rem 1.3rem; transition: transform var(--t) var(--ease); }
  .cs__next-card:hover .cs__next-core { transform: translateY(-3px); }
  .cs__next-k { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--accent); }
  .cs__next-t { display: block; font-size: var(--fs-lg); margin-top: 0.35rem; }
</style>

<style is:global>
  .prose > * + * { margin-top: 1.3rem; }
  .prose h2 { font-size: var(--fs-2xl); margin-top: 3rem; }
  .prose h2:first-child { margin-top: 0; }
  .prose h3 { font-size: var(--fs-lg); margin-top: 2rem; color: var(--text); }
  .prose p, .prose li { color: var(--text-dim); font-size: var(--fs-lg); line-height: 1.75; }
  .prose strong { color: var(--text); font-weight: 500; }
  .prose ul { list-style: none; padding: 0; display: grid; gap: 0.7rem; }
  .prose li { position: relative; padding-left: 1.4rem; }
  .prose li::before { content: ""; position: absolute; left: 0; top: 0.7em; width: 6px; height: 6px;
    border-radius: 50%; background: var(--accent); }
  .prose code { font-family: var(--font-mono); font-size: 0.88em; color: var(--accent);
    background: var(--accent-soft); padding: 0.12em 0.4em; border-radius: 5px; }
  .prose pre { background: var(--card); border: 0.5px solid var(--line); border-radius: var(--r-md);
    padding: 1.1rem 1.25rem; overflow-x: auto; box-shadow: inset 0 1px 0 0 var(--inset-hi); }
  .prose pre code { color: var(--text-dim); background: none; padding: 0; font-size: var(--fs-sm); line-height: 1.7; }
  .prose .lead { color: var(--text); font-size: var(--fs-xl); }
</style>
