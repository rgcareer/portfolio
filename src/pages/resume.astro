---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const summary =
  'AI enablement and adoption professional with 20+ years helping people adopt new technology, across retail, enterprise tech, and SaaS. I get AI into the hands of non-technical teams and build the tools myself. My background pairs people leadership (teams of 15 to 35) with hands-on AI work in prompt engineering, workflow automation, and change management.';

const competencies = [
  'AI Workflow Design & Implementation', 'Prompt Engineering (Claude, ChatGPT)', 'AI Adoption Strategy',
  'Technology Enablement & Training', 'Change Management', 'Workflow Automation (Zapier / Make)',
  'Cross-Functional Leadership', 'People Management (15-35 reports)', 'Onboarding & Activation',
  'CRM Optimization', 'Stakeholder Management', 'Digital Transformation',
];

const experience = [
  {
    role: 'AI Product Builder & Implementation Consultant', org: 'Smart Business AI LLC',
    where: 'Remote', when: 'Current',
    bullets: [
      'Builds AI-powered tools for home-service businesses with Claude, ChatGPT, and Perplexity, aimed at owners who are not technical.',
      'Owns the end-to-end product lifecycle: customer research, planning, development, positioning, marketing, delivery, and support.',
      'Applies prompt engineering, AI workflow design, and automation (Zapier / Make) to turn business needs into implementation-ready solutions and SOPs.',
    ],
  },
  {
    role: 'Social Media Manager (Digital Marketing & Analytics)', org: "Pablo's Trap Sauce",
    where: 'Remote', when: '12/2023 - Present',
    bullets: [
      'Improved online conversion 18% through A/B testing, audience analysis, and campaign optimization.',
      'Grew online revenue 23% in 6 months and social following 140% in 12 months via a repeatable, data-driven content system.',
    ],
  },
  {
    role: 'Sales Executive (Enablement & Process Optimization)', org: 'Vacasa',
    where: 'Boise, ID', when: '11/2021 - 12/2022',
    bullets: [
      'Implemented a CRM optimization strategy that increased lead conversion 20% and retention 10%.',
      'Built a property onboarding process that cut activation time 25%; co-led a 15-member training program that raised productivity 15%.',
      'Revitalized underperforming territories, improving sales performance 40% across consecutive quarters.',
    ],
  },
  {
    role: 'Account Executive', org: 'Intuit', where: 'Eagle, ID', when: '12/2019 - 02/2021',
    bullets: [
      'Guided SMB transitions to cloud and SaaS with consultative needs analysis and structured implementation.',
      'Used Salesforce and HubSpot segmentation to sharpen targeting; contributed to a 15% revenue increase.',
    ],
  },
  {
    role: 'Inside Sales Executive', org: 'Cradlepoint Inc.', where: 'Boise, ID', when: '04/2019 - 12/2019',
    bullets: [
      'Used Tableau trend analysis to improve conversion 22%; drove 119% territory growth through data-informed targeting.',
      'Expanded into IL and MN markets at 96% quota attainment in Q1; lifted qualified pipeline 35% via webinar programs.',
    ],
  },
  {
    role: 'Sales Expert (Enterprise Technology Adoption)', org: 'Apple', where: 'Boise, ID', when: '02/2015 - 05/2019',
    bullets: [
      'Led enterprise technology adoption and training for organizations including St. Luke’s Health Services and Dutch Bros Coffee.',
      'Generated $1M+ in annual personal sales (40% of store revenue); mentored 22+ team members, lifting NPS from 83 to 92.',
    ],
  },
  {
    role: 'Store Manager (Operations & Team Development)', org: 'Zumiez / Vans / Mainland Skate & Surf',
    where: 'Northern California', when: '2004 - 2015',
    bullets: [
      'Managed teams of 15-35 with full P&L ownership (payroll, inventory, operations) across multiple locations.',
      'Built repeatable hiring, onboarding, training, and performance-review processes that drove consistent revenue growth.',
    ],
  },
];

// Honest framing: these are active focus areas, NOT earned credentials.
const developing = [
  'Claude Certified Architect (Anthropic)',
  'AI workflow automation',
  'Enterprise AI adoption frameworks',
  'Enablement program design',
];
const education = [
  { name: 'Bachelor of Arts, History', org: 'Boise State University', when: '2019' },
  { name: 'Business Leadership Program', org: 'Boise State University', when: '2019' },
];
// ============================================================================
// PUBLISH GATE (CCA-F): uncomment ONLY when the exam is passed. Then:
//   1) render it in the sidebar as a "Certifications" block above Education,
//      using the same rs__line markup as the education entries,
//   2) move 'Claude Certified Architect (Anthropic)' OUT of `developing` above,
//   3) add the matching line to the ATS print PDF path.
// const certifications = [
//   { name: 'Claude Certified Architect - Foundations (CCA-F)', org: 'Anthropic', when: '2026' },
// ];
// ============================================================================
---
<BaseLayout title="Résumé" active="resume" description={`Résumé of ${site.name}, ${site.role}.`}>
  <section class="container rs">
    <header class="rs__head">
      <div class="rs__id">
        <p class="section-kicker">Résumé</p>
        <h1 class="rs__name display">{site.name}</h1>
        <p class="rs__role">{site.role}</p>
        <p class="rs__contact">
          <span>{site.location}</span>
          <a class="link-quiet" href={`mailto:${site.email}`}>{site.email}</a>
          <a class="link-quiet" href={site.links.linkedin} target="_blank" rel="me noopener">LinkedIn</a>
        </p>
        <p class="rs__print-contact">{site.location} · {site.email} · {site.links.linkedin.replace(/^https?:\/\/(www\.)?/, '')}</p>
      </div>
      <div class="rs__actions">
        <button class="btn btn--solid" id="rs-print" type="button">Download PDF</button>
        <a class="btn btn--line" href="/work">See the work</a>
      </div>
    </header>

    <p class="rs__summary reveal">{summary}</p>

    <div class="rs__grid">
      <div class="rs__main">
        <h2 class="rs__h reveal">Experience</h2>
        <ol class="rs__exp">
          {experience.map((e) => (
            <li class="rs__role-item reveal">
              <div class="rs__role-top">
                <span class="rs__role-name">{e.role}</span>
                <span class="rs__role-when">{e.when}</span>
              </div>
              <div class="rs__role-org">{e.org} · {e.where}</div>
              <ul class="rs__bullets">{e.bullets.map((b) => <li>{b}</li>)}</ul>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rs__side">
        <div class="rs__block reveal">
          <h2 class="rs__h">Core competencies</h2>
          <ul class="rs__chips">{competencies.map((c) => <li>{c}</li>)}</ul>
        </div>
        <div class="rs__block reveal">
          <h2 class="rs__h">Currently developing</h2>
          <ul class="rs__chips">{developing.map((d) => <li>{d}</li>)}</ul>
        </div>
        <div class="rs__block reveal">
          <h2 class="rs__h">Education</h2>
          {education.map((c) => (
            <div class="rs__line"><span class="rs__line-t">{c.name}</span><span class="rs__line-s">{c.org} · {c.when}</span></div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    document.getElementById('rs-print')?.addEventListener('click', () => window.print());
  </script>
</BaseLayout>

<style>
  .rs { padding-top: clamp(3.5rem, 8vw, 5.5rem); padding-bottom: 2rem; }
  .rs__head { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-end; justify-content: space-between; }
  .rs__name { font-size: clamp(2.2rem, 5vw, 3.6rem); margin-top: 0.7rem; }
  .rs__role { color: var(--accent); font-family: var(--font-mono); font-size: var(--fs-base); margin-top: 0.6rem; }
  .rs__contact { display: flex; flex-wrap: wrap; gap: 0.4rem 1.2rem; margin-top: 0.9rem; font-size: var(--fs-sm); color: var(--text-dim); }
  .rs__print-contact { display: none; }
  .rs__actions { display: flex; gap: 0.75rem; }

  .rs__summary { max-width: 70ch; color: var(--text-dim); font-size: var(--fs-lg); line-height: 1.75;
    margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--line); }

  .rs__grid { display: grid; gap: clamp(2rem, 5vw, 3.5rem); margin-top: clamp(2.5rem, 5vw, 3.5rem); }
  @media (min-width: 880px) { .rs__grid { grid-template-columns: 1.7fr 1fr; } }

  .rs__h { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--text-faint); margin-bottom: 1.3rem; }

  .rs__exp { list-style: none; display: grid; gap: 1.8rem; }
  .rs__role-item { padding-bottom: 1.8rem; border-bottom: 1px solid var(--line); }
  .rs__role-item:last-child { border-bottom: 0; }
  .rs__role-top { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: baseline; justify-content: space-between; }
  .rs__role-name { font-size: var(--fs-lg); font-weight: 600; color: var(--text); }
  .rs__role-when { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint); }
  .rs__role-org { color: var(--accent); font-size: var(--fs-sm); margin-top: 0.3rem; }
  .rs__bullets { list-style: none; display: grid; gap: 0.6rem; margin-top: 0.9rem; }
  .rs__bullets li { position: relative; padding-left: 1.3rem; color: var(--text-dim); font-size: var(--fs-base); line-height: 1.65; }
  .rs__bullets li::before { content: ""; position: absolute; left: 0; top: 0.65em; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }

  .rs__side { display: grid; gap: 2.2rem; align-content: start; }
  .rs__chips { list-style: none; display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .rs__chips li { font-size: var(--fs-sm); color: var(--text-dim); border: 1px solid var(--line-2); border-radius: var(--r-pill); padding: 0.3rem 0.7rem; }
  .rs__line { padding: 0.6rem 0; border-bottom: 1px solid var(--line); }
  .rs__line:last-child { border-bottom: 0; }
  .rs__line-t { display: block; color: var(--text); font-size: var(--fs-sm); }
  .rs__line-s { display: block; color: var(--text-faint); font-family: var(--font-mono); font-size: var(--fs-eyebrow); margin-top: 0.2rem; }
</style>

<style is:global>
  @media print {
    /* ATS-clean: single column, plain text, full contact, real selectable text. */
    .nav-wrap, .foot, .preloader, .cursor, .wipe, .progress, .hud, #cmdk, .rs__actions, .skip, .rs__contact { display: none !important; }
    html, body { background: #fff !important; }
    body, .rs__name, .rs__role-name, .rs__line-t { color: #000 !important; }
    .rs__name { text-transform: none !important; font-variation-settings: 'wdth' 100 !important; }
    .rs__summary, .rs__bullets li, .rs__role-org, .rs__role-when, .rs__line-s, .rs__h, .rs__print-contact { color: #222 !important; }
    .rs__role { color: #000 !important; }
    .rs { padding: 0 !important; }
    .rs__grid { grid-template-columns: 1fr !important; gap: 1.5rem !important; }
    .rs__side { gap: 1.3rem !important; }
    .reveal { opacity: 1 !important; transform: none !important; filter: none !important; }
    .rs__role-item, .rs__summary, .rs__line { border-color: #ccc !important; }
    .rs__print-contact { display: block !important; font-size: 12px; margin-top: 6px; }
    .rs__chips { gap: 0 !important; }
    .rs__chips li { border: 0 !important; padding: 0 !important; color: #222 !important; font-size: 12px; }
    .rs__chips li:not(:last-child)::after { content: " · "; color: #999; }
    a { color: #000 !important; text-decoration: none; }
  }
</style>
