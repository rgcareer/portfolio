---
import BaseLayout from './BaseLayout.astro';
import { getCase, work } from '../config/work';
import { site } from '../config/site';

interface Props { slug: string; }
const { slug } = Astro.props;
const c = getCase(slug)!;
const idx = work.findIndex((w) => w.slug === slug);
const next = work[(idx + 1) % work.length];
const plateNo = String(idx + 1).padStart(2, '0');
---

<BaseLayout title={c.title} active="work" description={c.tagline}>
  <article class="cs container">
    <a href="/work" class="cs__back" data-anim><span aria-hidden="true">←</span> Table of contents</a>

    <header class="cs__head" data-anim>
      <p class="cs__folio">Plate {plateNo} · {c.year}</p>
      <h1 class="cs__title">{c.title}</h1>
      <p class="cs__tagline">{c.tagline}</p>
    </header>

    <div class="cs__layout">
      <aside class="cs__rail" data-anim>
        <dl class="cs__meta">
          <div><dt>Role</dt><dd>{c.role}</dd></div>
          <div><dt>Status</dt><dd>{c.status}</dd></div>
          <div><dt>Stack</dt><dd>{c.stack.join(' · ')}</dd></div>
        </dl>
      </aside>

      <div class="cs__main">
        <div class="cs__metrics" data-anim>
          {c.metrics.map((m) => (
            <div class="cs__metric">
              <span class="cs__metric-v">{m.value}</span>
              <span class="cs__metric-l">{m.label}</span>
            </div>
          ))}
        </div>

        <figure class="cs__fig">
          {c.figure.src ? (
            <img src={c.figure.src} alt={c.figure.alt ?? ''} loading="eager" decoding="async" />
          ) : (
            <pre class="cs__specimen" aria-hidden="true">{c.figure.specimen?.join('\n')}</pre>
          )}
          <figcaption>Fig. {plateNo} · {c.figure.caption}</figcaption>
        </figure>

        <div class="cs__body prose">
          <slot />
        </div>

        <nav class="cs__next" aria-label="Next case study">
          <a href={`/work/${next.slug}`} class="cs__next-card">
            <span class="cs__next-k">Next plate →</span>
            <span class="cs__next-t">{next.title}</span>
          </a>
          <a href={`mailto:${site.email}`} class="btn btn--accent magnetic magnetic--soft cs__next-cta">
            Get in touch
            <span class="btn__ic" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
            </span>
          </a>
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .cs { padding-top: clamp(2.5rem, 6vw, 4.5rem); }
  .cs__back { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono);
    font-size: var(--fs-sm); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em;
    transition: color var(--t-fast) var(--ease); }
  .cs__back:hover { color: var(--accent); }
  .cs__back span { transition: transform var(--t) var(--ease); }
  .cs__back:hover span { transform: translateX(-3px); }

  .cs__head { margin-top: 2rem; border-bottom: 1.5px solid var(--line-strong); padding-bottom: clamp(1.6rem, 4vw, 2.4rem); }
  .cs__folio { font-family: var(--font-mono); font-size: var(--fs-eyebrow); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); }
  .cs__title { font-size: var(--fs-3xl); margin-top: 1rem; text-transform: uppercase;
    font-stretch: 118%; font-weight: 750; }
  .cs__tagline { font-size: var(--fs-xl); color: var(--text-dim); margin-top: 1rem; max-width: 44ch; }

  .cs__layout { display: grid; gap: clamp(2rem, 5vw, 4rem); margin-top: clamp(1.6rem, 4vw, 2.4rem); }
  @media (min-width: 900px) {
    .cs__layout { grid-template-columns: 230px minmax(0, 1fr); align-items: start; }
    .cs__rail { position: sticky; top: 6rem; }
  }
  .cs__main { min-width: 0; }

  .cs__meta { display: flex; flex-wrap: wrap; gap: 1.2rem 2.2rem; }
  @media (min-width: 900px) {
    .cs__meta { flex-direction: column; gap: 1.3rem; }
  }
  .cs__meta dt { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.16em; color: var(--text-faint); margin-bottom: 0.35rem; }
  .cs__meta dd { font-size: var(--fs-sm); color: var(--text); max-width: 22ch; }

  .cs__metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .cs__metric { background: var(--card); border: 1px solid var(--line-2); border-radius: var(--r-sm); padding: 1rem 1.1rem; }
  .cs__metric-v { display: block; font-family: var(--font-mono); font-size: var(--fs-xl); color: var(--accent); letter-spacing: -0.02em; }
  .cs__metric-l { display: block; font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-faint); margin-top: 0.4rem; }
  @media (max-width: 600px) { .cs__metrics { grid-template-columns: 1fr; } }

  .cs__fig { margin-top: 1.6rem; border: 1px solid var(--line-2); border-radius: var(--r-sm);
    background: var(--bg-1); padding: var(--bezel); }
  .cs__fig img { width: 100%; border-radius: 2px; border: 1px solid var(--line); }
  .cs__specimen { font-family: var(--font-mono); font-size: var(--fs-sm); line-height: 1.9;
    color: var(--text-dim); background: var(--card-2); border: 1px solid var(--line);
    border-radius: 2px; padding: 1.2rem 1.3rem; overflow-x: auto; }
  .cs__fig figcaption { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 0.12em; padding: 0.65rem 0.35rem 0.3rem; }

  .cs__body { max-width: 720px; margin-top: clamp(2.2rem, 5vw, 3.4rem); }

  .cs__next { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem; justify-content: space-between;
    margin-top: clamp(3.5rem, 8vw, 6rem); padding-top: 2.5rem; border-top: 1.5px solid var(--line-strong); }
  .cs__next-card { flex: 1 1 260px; border: 1px solid var(--line-2); border-radius: var(--r-sm);
    background: var(--card); padding: 1.1rem 1.3rem;
    transition: border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease); }
  .cs__next-card:hover { border-color: var(--accent-line); background: var(--bg-1); }
  .cs__next-k { font-family: var(--font-mono); font-size: var(--fs-eyebrow); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); }
  .cs__next-t { display: block; font-size: var(--fs-lg); font-weight: 600; margin-top: 0.35rem; }
</style>

<style is:global>
  .prose > * + * { margin-top: 1.3rem; }
  .prose h2 { font-size: var(--fs-2xl); margin-top: 3rem; }
  .prose h2:first-child { margin-top: 0; }
  .prose h3 { font-size: var(--fs-lg); margin-top: 2rem; color: var(--text); }
  .prose p, .prose li { color: var(--text-dim); font-size: var(--fs-lg); line-height: 1.75; }
  .prose strong { color: var(--text); font-weight: 600; }
  .prose ul { list-style: none; padding: 0; display: grid; gap: 0.7rem; }
  .prose li { position: relative; padding-left: 1.4rem; }
  .prose li::before { content: ""; position: absolute; left: 0; top: 0.72em; width: 7px; height: 7px;
    border-radius: 1px; background: var(--accent); }
  .prose code { font-family: var(--font-mono); font-size: 0.88em; color: var(--accent-press);
    background: var(--accent-soft); padding: 0.12em 0.4em; border-radius: 3px; }
  .prose pre { background: var(--card-2); border: 1px solid var(--line-2); border-radius: var(--r-sm);
    padding: 1.1rem 1.25rem; overflow-x: auto; }
  .prose pre code { color: var(--text-dim); background: none; padding: 0; font-size: var(--fs-sm); line-height: 1.7; }
  .prose .lead { color: var(--text); font-size: var(--fs-xl); }
</style>
