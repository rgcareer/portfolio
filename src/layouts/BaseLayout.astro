---
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  active?: string;
}
const { title, description, active } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} · ${site.role}`;
const desc = description ?? site.blurb;
const canonical = new URL(Astro.url.pathname, site.url).toString();

const nav = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/work', label: 'Work', key: 'work' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/resume', label: 'Résumé', key: 'resume' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  url: site.url,
  email: `mailto:${site.email}`,
  ...(site.links.linkedin.includes('REPLACE') ? {} : { sameAs: [site.links.linkedin] }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#07080B" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    <div class="bg-field" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>

    <a href="#main" class="skip">Skip to content</a>

    <header class="nav-wrap">
      <nav class="nav" aria-label="Primary">
        <a href="/" class="nav__brand" aria-label={`${site.name} — home`}>
          <span class="nav__mono">{site.initials}</span>
          <span class="nav__name">{site.name}</span>
        </a>
        <ul class="nav__links">
          {nav.filter((n) => n.key !== 'home').map((n) => (
            <li><a href={n.href} class:list={['nav__link', { 'is-active': active === n.key }]}>{n.label}</a></li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="foot">
      <div class="container foot__in">
        <div class="foot__id">
          <span class="nav__mono">{site.initials}</span>
          <div>
            <p class="foot__name">{site.name}</p>
            <p class="foot__role">{site.role}</p>
          </div>
        </div>
        <div class="foot__links">
          <a class="link-quiet" href={`mailto:${site.email}`}>Email</a>
          <a class="link-quiet" href={site.links.linkedin} rel="me noopener" target="_blank">LinkedIn</a>
          <a class="link-quiet" href="/resume">Résumé</a>
        </div>
        <p class="foot__meta">© {site.year} · {site.location}</p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const els = document.querySelectorAll('.reveal:not(.in)');
        if (!els.length || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('in'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <style>
      .skip { position: absolute; left: -9999px; top: 0; z-index: var(--z-overlay);
        background: var(--accent); color: var(--accent-text); padding: 0.6rem 1rem; border-radius: var(--r-sm); }
      .skip:focus { left: 1rem; top: 1rem; }

      .nav-wrap { position: sticky; top: 0; z-index: var(--z-nav); display: flex; justify-content: center; padding-top: 1.25rem; }
      .nav {
        display: flex; align-items: center; gap: clamp(1rem, 4vw, 2.5rem);
        width: min(100% - 2rem, var(--container));
        padding: 0.55rem 0.65rem 0.55rem 1.1rem;
        border-radius: 999px;
        background: rgba(13, 16, 22, 0.6);
        border: 0.5px solid var(--line-2);
        box-shadow: inset 0 1px 0 0 var(--inset-hi), 0 12px 40px -24px #000;
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
      }
      .nav__brand { display: inline-flex; align-items: center; gap: 0.6rem; margin-right: auto; }
      .nav__mono { font-family: var(--font-mono); font-weight: 500; font-size: 0.8rem;
        display: grid; place-items: center; width: 30px; height: 30px; flex: none;
        border: 0.5px solid var(--accent-line); border-radius: 9px; color: var(--accent); }
      .nav__name { font-weight: 500; font-size: var(--fs-sm); letter-spacing: -0.01em; }
      .nav__links { display: none; align-items: center; gap: 1.5rem; list-style: none; }
      .nav__link { font-size: var(--fs-sm); color: var(--text-dim); transition: color var(--t-fast) var(--ease); }
      .nav__link:hover, .nav__link.is-active { color: var(--text); }
      @media (min-width: 720px) { .nav__links { display: flex; } .nav__name { font-size: var(--fs-base); } }

      .foot { border-top: 0.5px solid var(--line); margin-top: var(--section-y); padding-block: 3rem; }
      .foot__in { display: flex; flex-wrap: wrap; align-items: center; gap: 1.5rem 2.5rem; }
      .foot__id { display: flex; align-items: center; gap: 0.8rem; margin-right: auto; }
      .foot__name { font-weight: 500; font-size: var(--fs-sm); }
      .foot__role { color: var(--text-dim); font-size: var(--fs-sm); }
      .foot__links { display: flex; gap: 1.5rem; font-size: var(--fs-sm); }
      .foot__meta { color: var(--text-faint); font-family: var(--font-mono); font-size: var(--fs-eyebrow); width: 100%; }
      @media (min-width: 720px) { .foot__meta { width: auto; } }
    </style>
  </body>
</html>
