---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
import { work } from '../config/work';

const spec = [
  { k: 'role', v: site.role },
  { k: 'status', v: 'Open to work', accent: true },
  { k: 'location', v: site.location },
  { k: 'focus', v: 'AI adoption · automation · enablement' },
  { k: 'tooling', v: 'Claude · Prompt engineering · MCP · Workflow automation · Zapier / Make · Python · Change management' },
];

const method = [
  { n: '01', t: 'Assess', d: 'Map the real workflows first. Where hours actually go, not where the demo looks good.' },
  { n: '02', t: 'Pilot', d: 'One team, one measurable workflow. Working tool over slideware, every time.' },
  { n: '03', t: 'Train', d: 'Playbooks people actually open. Meet them at their level and remove the fear.' },
  { n: '04', t: 'Measure', d: 'Adoption is a number, not a vibe. Usage, time saved, and whether it stuck.' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
---

<BaseLayout active="home">
  <!-- ============ COVER ============ -->
  <section class="cover container" data-sec="Cover">
    <span class="marks" id="cover-marks" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
    <div class="cover__folio" data-anim>
      <span id="folio-type" data-type="Field manual">Field manual</span>
      <span>Fig. 00 · Cover</span>
    </div>

    <h1 class="cover__name" aria-label={site.name}>
      <span class="mask"><span class="mask__in">{site.firstName}</span></span>
      <span class="mask"><span class="mask__in cover__last ink-sweep">Garver</span></span>
    </h1>

    <div class="cover__stamp" data-stamp aria-hidden="true">
      <span class="stamp__in">
        <b>Open to work</b>
        <i>Remote · US · {site.year}</i>
      </span>
    </div>

    <div class="cover__body">
      <p class="cover__tag" data-anim>{site.tagline}</p>
      <p class="cover__blurb" data-anim>{site.blurb}</p>
      <div class="cover__cta" data-anim>
        <a href="/work" class="btn btn--accent magnetic magnetic--soft">
          View the plates
          <span class="btn__ic" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
          </span>
        </a>
        <a href="/resume" class="btn btn--ghost magnetic magnetic--soft">
          Spec sheet
          <span class="btn__ic" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v8M3.5 6.5 7 10l3.5-3.5M2.5 12h9"/></svg>
          </span>
        </a>
        <a href={`mailto:${site.email}`} class="link-quiet cover__email">Get in touch</a>
      </div>
      <button class="cover__hint" data-anim data-cmdk type="button"><kbd>⌘</kbd><kbd>K</kbd> open the index</button>
    </div>

    <dl class="cover__spec">
      {spec.map((r) => (
        <div class="cover__row" data-specrow>
          <dt>{r.k}</dt>
          <dd class:list={[{ 'is-accent': r.accent }]}>{r.accent && <span class="dot" aria-hidden="true"></span>}{r.v}</dd>
        </div>
      ))}
    </dl>

    <p class="cover__note" data-anim>
      <span class="cover__note-pen" aria-hidden="true">✎</span>
      <span id="fieldnote" data-type="field note: adoption is a number, not a vibe.">field note: adoption is a number, not a vibe.</span><span class="type-caret" id="fieldnote-caret" aria-hidden="true" hidden></span>
    </p>
  </section>

  <!-- ============ THE PLATES ============ -->
  <section class="plates container" aria-label="Selected work" data-sec="Plates">
    <header class="plates__head">
      <h2 class="plates__title">The plates.</h2>
      <hr class="rule-draw reveal" aria-hidden="true" />
      <p class="plates__sub">Selected work, documented the way it shipped: figures, real numbers, method.</p>
    </header>

    <div class="plates__stack">
      {work.map((c, i) => (
        <article class="plate" style={`--i:${i}`}>
          <div class="plate__in">
            <span class="filed" aria-hidden="true">Filed · {site.year}</span>
            <div class="plate__meta">
              <span class="plate__no">Plate {pad(i)}</span>
              <span class="plate__tags">{c.tags.join(' · ')}</span>
            </div>
            <div class="plate__grid">
              <div class="plate__lead">
                <h3 class="plate__name">{c.title}</h3>
                <p class="plate__tagline">{c.tagline}</p>
                <dl class="plate__metrics">
                  {c.metrics.map((m) => (
                    <div>
                      <dd data-count={/^[\d,]+$/.test(m.value) ? m.value.replace(/,/g, '') : undefined}>{m.value}</dd>
                      <dt>{m.label}</dt>
                    </div>
                  ))}
                </dl>
                <a class="plate__link" href={`/work/${c.slug}`}>
                  Read the chapter <span aria-hidden="true">→</span>
                </a>
              </div>
              <figure class="plate__fig">
                <span class="plate__fig-frame">
                  {c.figure.src ? (
                    <img src={c.figure.src} alt={c.figure.alt ?? ''} loading="lazy" decoding="async" data-parallax />
                  ) : (
                    <pre class="plate__specimen" aria-hidden="true">{c.figure.specimen?.join('\n')}</pre>
                  )}
                </span>
                <figcaption>Fig. {pad(i)} · {c.figure.caption}</figcaption>
              </figure>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ THE METHOD ============ -->
  <section class="method container" aria-label="Method" data-sec="Method">
    <h2 class="method__title">The method.</h2>
    <hr class="rule-draw reveal" aria-hidden="true" />
    <ol class="method__list">
      {method.map((m) => (
        <li class="method__row">
          <span class="method__no" aria-hidden="true">{m.n}</span>
          <h3 class="method__t">{m.t}</h3>
          <p class="method__d">{m.d}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============ CUT LINE ============ -->
  <section class="cut container" aria-label="Contact" data-sec="Contact">
    <hr class="rule rule--dashed cut__rule" />
    <div class="cut__in">
      <h2 class="cut__title">Need a rollout run, or a tool built?</h2>
      <div class="cut__cta">
        <a href={`mailto:${site.email}`} class="btn btn--accent magnetic magnetic--soft">
          Request a briefing
          <span class="btn__ic" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
          </span>
        </a>
        <a href="/contact" class="link-quiet">or the long way, via the contact page</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- cover ---------- */
  .cover { position: relative; padding-top: clamp(2.5rem, 7vw, 5rem); }
  .cover__folio { display: flex; justify-content: space-between; gap: 1rem;
    font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.18em; color: var(--text-faint);
    border-bottom: 1px solid var(--line-2); padding-bottom: 0.8rem; }

  .cover__name { margin-top: clamp(1.5rem, 4vw, 2.8rem);
    font-size: var(--fs-hero); text-transform: uppercase;
    font-weight: 800; font-stretch: 122%; line-height: 0.92; letter-spacing: -0.015em; }
  .cover__last { color: transparent; -webkit-text-stroke: 2px var(--text); }

  .cover__stamp { position: absolute; right: var(--gutter); top: clamp(6rem, 16vw, 9.5rem);
    transform: rotate(-7deg); pointer-events: none; }
  .stamp__in { display: inline-flex; flex-direction: column; gap: 0.15rem; text-align: center;
    border: 2.5px solid var(--accent); outline: 1.5px solid var(--accent); outline-offset: 3px;
    border-radius: var(--r-sm); padding: 0.55rem 0.9rem; color: var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent); }
  .stamp__in b { font-family: var(--font-mono); font-weight: 600; font-size: 0.82rem;
    text-transform: uppercase; letter-spacing: 0.16em; }
  .stamp__in i { font-family: var(--font-mono); font-style: normal; font-size: 0.6rem;
    text-transform: uppercase; letter-spacing: 0.2em; }
  @media (max-width: 720px) { .cover__stamp { position: static; margin-top: 1.4rem; transform: rotate(-4deg); display: inline-block; } }

  .cover__body { max-width: 62ch; }
  .cover__tag { font-size: var(--fs-2xl); font-weight: 600; letter-spacing: -0.025em;
    line-height: 1.15; margin-top: clamp(1.6rem, 4vw, 2.6rem); max-width: 24ch; }
  .cover__blurb { margin-top: 1.1rem; max-width: 52ch; color: var(--text-dim); font-size: var(--fs-lg); }
  .cover__cta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.85rem; margin-top: 2rem; }
  .cover__email { font-size: var(--fs-sm); margin-left: 0.4rem; }
  .cover__hint { display: inline-flex; align-items: center; gap: 0.15rem; margin-top: 1.5rem;
    font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint);
    transition: color var(--t-fast) var(--ease); }
  .cover__hint:hover { color: var(--text-dim); }
  .cover__hint kbd { border: 1px solid var(--line-2); border-radius: 3px; padding: 0.1em 0.45em;
    margin-right: 0.25em; color: var(--text-dim); background: var(--card); }

  .cover__note { margin-top: 1.4rem; font-family: var(--font-mono); font-size: var(--fs-sm);
    color: var(--text-dim); letter-spacing: 0.01em; }
  .cover__note-pen { color: var(--accent); margin-right: 0.4em; }

  .cover__spec { margin-top: clamp(2.5rem, 6vw, 4rem); border-top: 1px solid var(--line-strong); }
  .cover__row { display: grid; grid-template-columns: 110px 1fr; gap: 1rem; align-items: baseline;
    padding: 0.85rem 0; border-bottom: 1px solid var(--line); }
  @media (min-width: 720px) { .cover__row { grid-template-columns: 160px 1fr; } }
  .cover__row dt { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.16em; color: var(--text-faint); }
  .cover__row dd { font-size: var(--fs-sm); color: var(--text); }
  .cover__row dd.is-accent { color: var(--accent); font-weight: 600; display: inline-flex; align-items: center; gap: 0.5em; }

  /* ---------- plates ---------- */
  .plates { padding-top: var(--section-y); }
  .plates__head { max-width: 720px; margin-bottom: clamp(2rem, 5vw, 3.2rem); }
  .plates__title { font-size: var(--fs-3xl); text-transform: uppercase; font-stretch: 118%; font-weight: 750; }
  .plates__sub { margin-top: 0.9rem; color: var(--text-dim); font-size: var(--fs-lg); max-width: 46ch; }

  .plates__stack { display: grid; gap: clamp(1.2rem, 3vw, 2rem); }
  .plate { position: sticky; top: calc(64px + var(--i) * 14px); }
  .plate__in { position: relative; background: var(--card); border: 1px solid var(--line-2); border-radius: var(--r-md);
    padding: clamp(1.2rem, 3vw, 2rem); box-shadow: 0 -8px 24px -20px rgba(32, 29, 26, 0.5);
    transform-origin: center top; will-change: transform; }
  .plate__meta { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
    border-bottom: 1px solid var(--line); padding-bottom: 0.85rem; }
  .plate__no { font-family: var(--font-mono); font-size: var(--fs-eyebrow); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); }
  .plate__tags { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint);
    text-align: right; }

  .plate__grid { display: grid; gap: clamp(1.4rem, 3vw, 2.4rem); margin-top: 1.4rem; }
  @media (min-width: 880px) { .plate__grid { grid-template-columns: 0.95fr 1.05fr; align-items: start; } }

  .plate__name { font-size: var(--fs-2xl); letter-spacing: -0.02em; }
  .plate__tagline { margin-top: 0.7rem; color: var(--text-dim); font-size: var(--fs-lg); max-width: 44ch; }
  .plate__metrics { display: flex; flex-wrap: wrap; gap: 1.4rem 2.2rem; margin-top: 1.6rem; }
  .plate__metrics dd { font-family: var(--font-mono); font-size: var(--fs-xl); font-weight: 500; color: var(--text); }
  .plate__metrics dt { font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--text-faint); margin-top: 0.3rem; }
  .plate__link { display: inline-flex; align-items: center; gap: 0.5em; margin-top: 1.8rem;
    font-family: var(--font-mono); font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--accent); border-bottom: 1px solid var(--accent-line);
    padding-bottom: 0.15em; transition: gap var(--t-fast) var(--ease); }
  .plate__link:hover { gap: 0.8em; }

  .plate__fig { border: 1px solid var(--line-2); border-radius: var(--r-sm); background: var(--bg-1);
    padding: var(--bezel); }
  .plate__fig-frame { display: block; overflow: hidden; border-radius: 2px; }
  .plate__fig img { width: 100%; border-radius: 2px; border: 1px solid var(--line);
    will-change: transform; }
  .plate__specimen { font-family: var(--font-mono); font-size: var(--fs-sm); line-height: 1.9;
    color: var(--text-dim); background: var(--card-2); border: 1px solid var(--line);
    border-radius: 2px; padding: 1.2rem 1.3rem; overflow-x: auto; }
  .plate__fig figcaption { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 0.12em; padding: 0.65rem 0.35rem 0.3rem; }

  /* ---------- method ---------- */
  .method { padding-top: var(--section-y); }
  .method__title { font-size: var(--fs-3xl); text-transform: uppercase; font-stretch: 118%; font-weight: 750; }
  .method__list { list-style: none; margin-top: clamp(1.8rem, 4vw, 2.8rem); border-top: 1px solid var(--line-strong); }
  .method__row { display: grid; grid-template-columns: 3.5rem 1fr; gap: 0.3rem 1.2rem;
    padding: 1.4rem 0; border-bottom: 1px solid var(--line); align-items: baseline; }
  @media (min-width: 760px) { .method__row { grid-template-columns: 5rem 220px 1fr; gap: 1.5rem; } }
  .method__no { font-family: var(--font-mono); font-size: var(--fs-lg); color: var(--accent); font-weight: 500; }
  .method__t { font-size: var(--fs-xl); letter-spacing: -0.01em; }
  .method__d { grid-column: 2; color: var(--text-dim); max-width: 56ch; }
  @media (min-width: 760px) { .method__d { grid-column: auto; } }

  /* ---------- cut line ---------- */
  .cut { padding-top: var(--section-y); }
  .cut__rule { border-top-width: 1.5px; }
  .cut__in { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1.5rem; padding-top: clamp(2rem, 5vw, 3.2rem); }
  .cut__title { font-size: var(--fs-2xl); max-width: 20ch; letter-spacing: -0.02em; }
  .cut__cta { display: flex; flex-wrap: wrap; align-items: center; gap: 1.1rem; }
</style>
