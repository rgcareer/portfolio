---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { work } from '../../config/work';
const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<BaseLayout title="Work" active="work" description="A few working projects with real code behind them: AI tools, automation, and systems I built to solve my own problems.">
  <section class="container wk">
    <header class="wk__head">
      <p class="wk__folio" data-anim>Table of contents</p>
      <h1 class="wk__title" data-anim>A few things I've built.</h1>
      <p class="wk__sub" data-anim>Working projects with code behind them. Mostly AI tools and automation, plus a couple of systems I built to fix my own problems.</p>
    </header>

    <ol class="wk__toc">
      {work.map((c, i) => (
        <li class="wk__row" style={`--i:${i}`}>
          <a href={`/work/${c.slug}`} class="wk__entry">
            <span class="wk__no">Plate {pad(i)}</span>
            <span class="wk__main">
              <span class="wk__name">{c.title}</span>
              <span class="wk__leader" aria-hidden="true"></span>
              <span class="wk__metric">{c.metrics[0].value} {c.metrics[0].label.toLowerCase()}</span>
            </span>
            <span class="wk__line">{c.tagline}</span>
            <span class="wk__foot">
              <span class="wk__status">{c.status}</span>
              <span class="wk__tags">{c.tags.join(' · ')}</span>
              <span class="wk__go" aria-hidden="true">→</span>
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .wk { padding-top: clamp(3rem, 7vw, 5.5rem); }
  .wk__head { max-width: 760px; }
  .wk__folio { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase;
    letter-spacing: 0.18em; color: var(--text-faint); }
  .wk__title { font-size: var(--fs-3xl); margin-top: 1.1rem; text-transform: uppercase;
    font-stretch: 118%; font-weight: 750; }
  .wk__sub { font-size: var(--fs-lg); color: var(--text-dim); margin-top: 1.1rem; max-width: 48ch; }

  .wk__toc { list-style: none; margin-top: clamp(2.5rem, 6vw, 4rem); border-top: 1.5px solid var(--line-strong); }
  .wk__entry { display: grid; gap: 0.45rem 1.5rem; padding: 1.6rem 0.2rem;
    border-bottom: 1px solid var(--line); transition: background var(--t-fast) var(--ease); }
  .wk__row:last-child .wk__entry { border-bottom: 1.5px solid var(--line-strong); }
  .wk__entry:hover { background: var(--card); }

  .wk__no { font-family: var(--font-mono); font-size: var(--fs-eyebrow); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); }
  .wk__main { display: flex; align-items: baseline; gap: 0.9rem; min-width: 0; }
  .wk__name { font-size: var(--fs-2xl); font-weight: 600; letter-spacing: -0.02em; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; transition: color var(--t-fast) var(--ease); }
  .wk__entry:hover .wk__name { color: var(--accent); }
  .wk__leader { flex: 1; min-width: 2rem; border-bottom: 2px dotted var(--line-2);
    transform: translateY(-0.35em) scaleX(0.45); transform-origin: left; opacity: 0.55;
    transition: transform 0.55s var(--ease-out), opacity 0.55s var(--ease-out), border-color 0.55s var(--ease-out); }
  .wk__entry:hover .wk__leader { transform: translateY(-0.35em) scaleX(1); opacity: 1; border-color: var(--accent-line); }
  .wk__metric { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--text-dim); white-space: nowrap; }
  .wk__line { color: var(--text-dim); font-size: var(--fs-lg); max-width: 56ch; }
  .wk__foot { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem 1.6rem; margin-top: 0.5rem;
    font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 0.1em; }
  .wk__go { margin-left: auto; font-size: var(--fs-lg); color: var(--text-dim);
    transition: transform var(--t-fast) var(--ease), color var(--t-fast) var(--ease); }
  .wk__entry:hover .wk__go { transform: translateX(5px); color: var(--accent); }

  @media (max-width: 640px) {
    .wk__main { flex-wrap: wrap; gap: 0.3rem 0.9rem; }
    .wk__name { white-space: normal; }
    .wk__leader { display: none; }
  }
</style>
