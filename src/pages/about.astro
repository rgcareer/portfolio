---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const throughline = [
  { when: '2004–2015', role: 'Retail management', org: 'Zumiez · Vans · Mainland',
    work: 'Led teams of 15–35 and built the hiring, onboarding, and training systems that made new people productive.' },
  { when: '2015–2019', role: 'Enterprise technology adoption', org: 'Apple',
    work: 'Got organizations like St. Luke’s and Dutch Bros onto new tools, trained 22+ teammates, and lifted NPS from 83 to 92.' },
  { when: '2019–2022', role: 'SaaS sales & enablement', org: 'Cradlepoint · Intuit · Vacasa',
    work: 'Moved SMBs onto cloud and SaaS — CRM optimization, onboarding processes, and training programs that stuck.' },
  { when: 'Current', role: 'AI product builder', org: 'Smart Business AI',
    work: 'Build AI products for non-technical business owners end to end: research, design, build, deliver, support.' },
];
---
<BaseLayout title="About" active="about" description="Ryan Garver — twenty years helping people adopt new technology, now focused on AI.">
  <section class="container ab">
    <header class="ab__head">
      <span class="eyebrow eyebrow--pill" data-anim>// about</span>
      <h1 class="ab__title" data-anim>I help people adopt what's new. For twenty years — now it's AI.</h1>
      <p class="ab__lead" data-anim>
        I'm {site.firstName}. Across retail, enterprise tech, and SaaS, I've spent two decades doing one thing in
        different forms: helping non-technical people actually adopt new technology and new ways of working.
        AI is the same job — higher stakes, faster clock.
      </p>
    </header>

    <section class="ab__sec">
      <h2 class="ab__h reveal">The throughline</h2>
      <p class="ab__p reveal">Every role I've held was an adoption problem wearing a different costume.</p>
      <ol class="ab__time">
        {throughline.map((t) => (
          <li class="ab__item reveal">
            <span class="ab__when">{t.when}</span>
            <div class="ab__item-body">
              <span class="ab__role">{t.role} <span class="ab__org">· {t.org}</span></span>
              <p class="ab__work">{t.work}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="ab__sec">
      <h2 class="ab__h reveal">The part that's rare</h2>
      <div class="ab__combo">
        <div class="bezel reveal"><div class="bezel__core ab__card">
          <span class="ab__card-k">I lead change</span>
          <p class="ab__card-p">Twenty years moving people and teams through new tools and processes — training, onboarding, enablement, stakeholder buy-in. The human side of adoption, where most rollouts actually succeed or fail.</p>
        </div></div>
        <div class="bezel reveal"><div class="bezel__core ab__card">
          <span class="ab__card-k">And I build</span>
          <p class="ab__card-p">I don't just talk about AI — I ship it. Prompt engineering, workflow automation, an MCP server, a job-intelligence engine, a multi-agent workflow system. <a class="ab__link" href="/work">See the work →</a></p>
        </div></div>
      </div>
      <p class="ab__pull reveal">Most AI-enablement people can't build. Most builders can't lead adoption. I do both.</p>
    </section>

    <section class="ab__sec">
      <h2 class="ab__h reveal">Where I'm headed</h2>
      <p class="ab__p reveal">
        I'm targeting roles where that combination matters: <strong>AI Enablement and Adoption</strong>, plus Customer
        Success, onboarding, and workforce AI training at companies doing AI well. I'm early in AI by title — deliberately
        so. I'd rather prove it with shipped work than a job description.
      </p>
      <div class="ab__cta reveal">
        <a href="/resume" class="btn btn--accent magnetic">Read the résumé
          <span class="btn__ic" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v8M3.5 6.5 7 10l3.5-3.5M2.5 12h9"/></svg></span>
        </a>
        <a href={`mailto:${site.email}`} class="btn btn--ghost magnetic">Get in touch</a>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .ab { padding-top: clamp(3rem, 7vw, 5rem); }
  .ab__head { max-width: 760px; }
  .ab__title { font-size: var(--fs-3xl); margin-top: 1.2rem; max-width: 18ch; }
  .ab__lead { font-size: var(--fs-xl); color: var(--text); margin-top: 1.5rem; line-height: 1.55; max-width: 54ch; }

  .ab__sec { margin-top: clamp(3.5rem, 8vw, 6rem); max-width: 820px; }
  .ab__h { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: 0.18em; color: var(--text-faint); }
  .ab__p { font-size: var(--fs-lg); color: var(--text-dim); margin-top: 1.1rem; max-width: 56ch; line-height: 1.7; }
  .ab__p strong { color: var(--text); font-weight: 500; }

  .ab__time { list-style: none; margin-top: 2rem; border-left: 0.5px solid var(--line-2); }
  .ab__item { display: grid; gap: 0.3rem 1.5rem; padding: 0 0 1.8rem 1.6rem; position: relative; }
  .ab__item:last-child { padding-bottom: 0; }
  .ab__item::before { content: ""; position: absolute; left: -3.5px; top: 0.45rem; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  @media (min-width: 640px) { .ab__item { grid-template-columns: 110px 1fr; } }
  .ab__when { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint); padding-top: 0.15rem; }
  .ab__role { font-size: var(--fs-lg); color: var(--text); font-weight: 500; }
  .ab__org { color: var(--accent); font-weight: 400; font-size: var(--fs-sm); }
  .ab__work { color: var(--text-dim); margin-top: 0.4rem; line-height: 1.6; }

  .ab__combo { display: grid; gap: 1rem; margin-top: 1.8rem; }
  @media (min-width: 720px) { .ab__combo { grid-template-columns: 1fr 1fr; } }
  .ab__card { padding: 1.4rem 1.5rem; height: 100%; }
  .ab__card-k { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); }
  .ab__card-p { color: var(--text-dim); margin-top: 0.8rem; line-height: 1.65; }
  .ab__link { color: var(--text); border-bottom: 1px solid var(--accent-line); transition: color var(--t-fast) var(--ease); }
  .ab__link:hover { color: var(--accent); }
  .ab__pull { font-size: var(--fs-2xl); color: var(--text); letter-spacing: -0.02em; line-height: 1.25; margin-top: 2.2rem; max-width: 30ch; }

  .ab__cta { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
</style>
