---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { work } from '../../config/work';
const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<BaseLayout title="Work" active="work" description="A few working projects with real code behind them: AI tools, automation, and systems I built to solve my own problems.">
  <section class="container wkx">
    <header class="wkx__head">
      <p class="section-kicker reveal">Selected work</p>
      <h1 class="wkx__title display reveal" data-stretch>A few things I've built</h1>
      <p class="wkx__sub reveal">Working projects with code behind them. Mostly AI tools and automation, plus a couple of systems I built to fix my own problems.</p>
    </header>

    <ol class="wkx__list">
      {work.map((c, i) => (
        <li class="wkx__row reveal">
          <a href={`/work/${c.slug}`} class="wkx__link" data-cursor="View">
            <span class="wkx__no">{pad(i)}</span>
            <span class="wkx__name display">{c.title}</span>
            <span class="wkx__body">
              <span class="wkx__tagline">{c.tagline}</span>
              <span class="wkx__detail">{c.status} · {c.tags.join(' · ')}</span>
            </span>
            <span class="wkx__metric">{c.metrics[0].value}<em>{c.metrics[0].label}</em></span>
            <span class="wkx__arrow" aria-hidden="true"></span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .wkx { padding-top: clamp(3.5rem, 8vw, 6rem); }
  .wkx__head { max-width: 780px; }
  .wkx__title { font-size: clamp(2.4rem, 6vw, 4.6rem); margin-top: 0.8rem; }
  .wkx__sub { font-size: var(--fs-lg); color: var(--text-dim); margin-top: 1.2rem; max-width: 50ch; }

  .wkx__list { list-style: none; margin-top: clamp(2.5rem, 6vw, 4rem); border-top: 1px solid var(--line-3); }
  .wkx__link {
    display: grid; align-items: center; gap: 0.3rem 1.5rem;
    grid-template-columns: auto 1fr auto auto;
    grid-template-areas: 'no name metric arrow' 'no body body arrow';
    padding: clamp(1.4rem, 3vw, 2.2rem) 0.2rem;
    border-bottom: 1px solid var(--line);
    transition: padding-left var(--t) var(--ease-out);
  }
  .wkx__row:last-child .wkx__link { border-bottom: 1px solid var(--line-3); }
  .wkx__link:hover { padding-left: 0.6rem; }

  .wkx__no { grid-area: no; font-family: var(--font-mono); font-size: var(--fs-eyebrow); font-weight: 500;
    letter-spacing: 0.1em; color: var(--accent); align-self: start; padding-top: 0.5rem; }
  .wkx__name { grid-area: name; font-size: clamp(1.7rem, 4.2vw, 3.2rem); color: var(--text);
    font-variation-settings: 'wdth' 100; transition: font-variation-settings var(--t) var(--ease-out), color var(--t) var(--ease-out); }
  .wkx__link:hover .wkx__name { color: var(--accent); font-variation-settings: 'wdth' 125; }
  .wkx__body { grid-area: body; display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .wkx__tagline { color: var(--text-dim); font-size: var(--fs-base); max-width: 52ch; }
  .wkx__detail { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 0.1em; }
  .wkx__metric { grid-area: metric; justify-self: end; text-align: right; font-family: var(--font-mono);
    font-size: var(--fs-lg); color: var(--text); white-space: nowrap; }
  .wkx__metric em { display: block; font-style: normal; font-size: 0.6rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-faint); margin-top: 0.3rem; }
  .wkx__arrow { grid-area: arrow; width: 1.5rem; height: 1.5rem; flex: none; background-color: var(--text-dim);
    -webkit-mask: var(--arrow-right) center / contain no-repeat; mask: var(--arrow-right) center / contain no-repeat;
    transition: transform var(--t) var(--ease-out), background-color var(--t) var(--ease-out); }
  .wkx__link:hover .wkx__arrow { transform: translateX(6px); background-color: var(--accent); }

  @media (max-width: 700px) {
    .wkx__link { grid-template-columns: auto 1fr auto;
      grid-template-areas: 'no name arrow' 'no body body' 'no metric metric'; }
    .wkx__metric { justify-self: start; text-align: left; margin-top: 0.4rem; }
  }
</style>
