---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---
<BaseLayout title="Contact" active="contact" description="Get in touch.">
  <section class="container section">
    <span class="eyebrow eyebrow--pill"><span class="dot" aria-hidden="true"></span> Available</span>
    <h1 style="font-size: var(--fs-3xl); margin-top: 1.2rem; max-width: 14ch;">Let's talk.</h1>
    <p style="color: var(--text-dim); margin-top: 1rem; max-width: 42ch;">The fastest way to reach me:</p>
    <div style="display:flex; flex-wrap:wrap; gap:0.85rem; margin-top:1.6rem;">
      <a href={`mailto:${site.email}`} class="btn btn--accent">Email me
        <span class="btn__ic" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
        </span>
      </a>
      <a href={site.links.linkedin} target="_blank" rel="me noopener" class="btn btn--ghost">LinkedIn
        <span class="btn__ic" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 11 3M5 3h6v6"/></svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
