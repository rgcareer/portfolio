---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.astro';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  active?: string;
}
const { title, description, active } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.role}`;
const desc = description ?? site.blurb;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImage = new URL('/og.png', site.url).toString();

const nav = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/work', label: 'Work', key: 'work' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/resume', label: 'Résumé', key: 'resume' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  url: site.url,
  email: `mailto:${site.email}`,
  ...(site.links.linkedin.includes('REPLACE') ? {} : { sameAs: [site.links.linkedin] }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0F0F11" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name}, ${site.role}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preload" href="/fonts/anybody-latin-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/bricolage-latin-var.woff2" as="font" type="font/woff2" crossorigin />

    <noscript><style>.preloader { display: none !important; }</style></noscript>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />
    <ClientRouter />
  </head>
  <body>
    <!-- global chrome (persists across page transitions; init once) -->
    <div class="preloader" id="preloader" transition:persist="preloader" aria-hidden="true">
      <div class="preloader__inner">
        <span class="preloader__name">{site.initials}</span>
        <span class="preloader__count" id="preloader-count">0</span>
      </div>
      <div class="preloader__bar"><span id="preloader-fill"></span></div>
    </div>
    <div class="progress" id="progress" transition:persist="progress" aria-hidden="true"><span id="progress-fill"></span></div>
    <div class="cursor" id="cursor" transition:persist="cursor" aria-hidden="true"><span class="cursor__label" id="cursor-label"></span></div>
    <div class="wipe" id="wipe" transition:persist="wipe" aria-hidden="true"></div>

    <a href="#main" class="skip">Skip to content</a>

    <header class="nav-wrap">
      <nav class="nav container" aria-label="Primary">
        <a href="/" class="nav__brand" aria-label={`${site.name}, home`}>
          <span class="nav__mono">{site.initials}</span>
          <span class="nav__name">{site.name}</span>
        </a>
        <ul class="nav__links">
          {nav.filter((n) => n.key !== 'home').map((n) => (
            <li><a href={n.href} class:list={['nav__link', { 'is-active': active === n.key }]}>{n.label}</a></li>
          ))}
        </ul>
        <button class="nav__cmd" data-cmdk type="button" aria-label="Open command menu" aria-keyshortcuts="Meta+K">
          <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><circle cx="9" cy="9" r="5.2"/><path d="m13 13 3 3"/></svg>
          <span class="nav__cmd-keys"><kbd>⌘</kbd><kbd>K</kbd></span>
        </button>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="foot">
      <div class="container foot__in">
        <div class="foot__id">
          <span class="nav__mono">{site.initials}</span>
          <div>
            <p class="foot__name">{site.name}</p>
            <p class="foot__role">{site.role}</p>
          </div>
        </div>
        <div class="foot__links">
          <a class="link-quiet" href={`mailto:${site.email}`}>Email</a>
          <a class="link-quiet" href={site.links.linkedin} rel="me noopener" target="_blank">LinkedIn</a>
          <a class="link-quiet" href="/resume">Résumé</a>
          <a class="link-quiet" href="/consulting">Consulting</a>
        </div>
        <p class="foot__meta">© {site.year} · {site.location} · Set in Anybody, Bricolage Grotesque &amp; Martian Mono</p>
      </div>
    </footer>

    <CommandPalette />

    <script>
      import '../scripts/motion.ts';
    </script>

    <style>
      .skip { position: fixed; left: 1rem; top: -4rem; z-index: var(--z-overlay);
        background: var(--accent); color: var(--accent-text); padding: 0.6rem 1rem; border-radius: var(--r-sm);
        transition: top var(--t) var(--ease-out); }
      .skip:focus { top: 1rem; }

      .nav-wrap { position: sticky; top: 0; z-index: var(--z-nav);
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        -webkit-backdrop-filter: saturate(1.4) blur(10px);
        backdrop-filter: saturate(1.4) blur(10px);
        border-bottom: 1px solid var(--line); }
      .nav { display: flex; align-items: center; gap: clamp(1rem, 3vw, 2.2rem); padding-block: 0.85rem; }
      .nav__brand { display: inline-flex; align-items: center; gap: 0.65rem; margin-right: auto; }
      .nav__mono { font-family: var(--font-mono); font-weight: 600; font-size: 0.78rem;
        display: grid; place-items: center; width: 30px; height: 30px; flex: none;
        border: 1.5px solid var(--accent); border-radius: var(--r-sm); color: var(--accent); letter-spacing: 0.02em; }
      .nav__name { font-weight: 600; font-size: var(--fs-sm); letter-spacing: -0.01em; }
      .nav__links { display: none; align-items: center; gap: 1.6rem; list-style: none; }
      .nav__link { font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-dim);
        text-transform: uppercase; letter-spacing: 0.06em;
        transition: color var(--t-fast) var(--ease-out); border-bottom: 1px solid transparent; padding-bottom: 2px; }
      .nav__link:hover { color: var(--text); }
      .nav__link.is-active { color: var(--accent); border-bottom-color: var(--accent); }
      @media (min-width: 720px) { .nav__links { display: flex; } .nav__name { font-size: var(--fs-base); } }
      .nav__cmd { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.42rem 0.55rem;
        border: 1px solid var(--line-2); border-radius: var(--r-sm); color: var(--text-dim);
        background: var(--bg-1); transition: color var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out); }
      .nav__cmd:hover { color: var(--text); border-color: var(--line-3); }
      .nav__cmd-keys { display: none; gap: 2px; }
      .nav__cmd kbd { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-faint);
        border: 1px solid var(--line); border-radius: 3px; padding: 0.05em 0.3em; }
      @media (min-width: 720px) { .nav__cmd { padding: 0.42rem 0.45rem 0.42rem 0.7rem; } .nav__cmd-keys { display: inline-flex; } }

      .foot { border-top: 1px solid var(--line); margin-top: var(--section-y); padding-block: 3rem; }
      .foot__in { display: flex; flex-wrap: wrap; align-items: center; gap: 1.5rem 2.5rem; }
      .foot__id { display: flex; align-items: center; gap: 0.8rem; margin-right: auto; }
      .foot__name { font-weight: 600; font-size: var(--fs-sm); }
      .foot__role { color: var(--text-dim); font-size: var(--fs-sm); }
      .foot__links { display: flex; gap: 1.5rem; font-size: var(--fs-sm); }
      .foot__meta { color: var(--text-faint); font-family: var(--font-mono); font-size: var(--fs-eyebrow); width: 100%; letter-spacing: 0.02em; }
      @media (min-width: 720px) { .foot__meta { width: auto; } }
    </style>
  </body>
</html>
